package sqlite3

import (
	"database/sql"
	"fmt"
	"time"

	"github.com/jadefish/avatar/login"
	"github.com/jmoiron/sqlx"

	"github.com/jadefish/avatar"
)

type accountRepo struct {
	db *sqlx.DB
}

var _ login.AccountRepository = &accountRepo{}

// NewAccountRepo creates a new account repository using the provided DB as
// storage.
func NewAccountRepo(db *sqlx.DB) *accountRepo {
	return &accountRepo{db}
}

// Create an Account, persisting it to the underlying storage.
func (repo *accountRepo) Create(data login.CreateAccount) error {
	err := transaction(repo.db, func(tx *sqlx.Tx) error {
		now := time.Now()
		query := repo.db.Rebind(`
			insert into accounts (name, email, password_hash, creation_ip, blocked, created_at, updated_at)
			values (?, ?, ?, ?, ?, ?);
		`)
		_, err := tx.Exec(query,
			data.Name,
			data.Email,
			data.PasswordHash,
			data.CreationIP,
			false,
			now,
			now)

		return err
	})

	if err != nil {
		return fmt.Errorf("create account: %w", err)
	}

	return nil
}

// Delete an existing account by ID.
func (repo *accountRepo) Delete(id avatar.EntityID) error {
	err := transaction(repo.db, func(tx *sqlx.Tx) error {
		query := tx.Rebind(`
			update accounts
			set deleted_at = ?, updated_at = ?
			where id = ?;
		`)
		now := time.Now()
		_, err := tx.Exec(query, now, now, id)

		return err
	})

	if err != nil {
		return fmt.Errorf("delete account: %w", err)
	}

	return nil
}

// Get retrieves an Account by its ID.
func (repo *accountRepo) Find(id avatar.EntityID) (*login.Account, error) {
	account := &login.Account{}
	err := transaction(repo.db, func(tx *sqlx.Tx) error {
		query := repo.db.Rebind(`
			select a.*
			from accounts a
			where a.id = ?
			and a.deleted_at is null;
		`)

		return repo.db.Get(account, query, id)
	})

	if err == sql.ErrNoRows {
		return nil, nil
	}

	if err != nil {
		return nil, err
	}

	return account, nil
}

// Update an Account.
func (repo *accountRepo) Update(
	id avatar.EntityID,
	data login.UpdateAccountData,
) error {
	err := transaction(repo.db, func(tx *sqlx.Tx) error {
		query := tx.Rebind(`
			update accounts
			set name = ?, email = ?, password_hash = ?, blocked = ?, updated_at = ?
			where id = ?;
		`)
		now := time.Now()
		_, err := tx.Exec(query,
			data.Name,
			data.Email,
			data.PasswordHash,
			data.Blocked,
			now)

		return err
	})

	if err != nil {
		return fmt.Errorf("update account: %w", err)
	}

	return nil
}

// FindByName retrieves an account by its name.
// No error is returned if the account could not be found.
func (repo *accountRepo) FindByName(name string) (*login.Account, error) {
	account := &login.Account{}
	err := transaction(repo.db, func(tx *sqlx.Tx) error {
		query := repo.db.Rebind(`
			select a.*
			from accounts a
			where a.name = ?
			and a.deleted_at is null
			limit 1;
		`)

		return repo.db.Get(account, query, name)
	})

	if err == sql.ErrNoRows {
		return nil, nil
	}

	if err != nil {
		return nil, err
	}

	return account, nil
}

// FindByEmail retrieves an account by its email.
// No error is returned if the account could not be found.
func (repo *accountRepo) FindByEmail(email string) (*login.Account, error) {
	account := &login.Account{}
	err := transaction(repo.db, func(tx *sqlx.Tx) error {
		query := repo.db.Rebind(`
			select a.*
			from accounts a
			where a.email = ?
			and a.deleted_at is null
			limit 1;
		`)

		return repo.db.Get(account, query, email)
	})

	if err == sql.ErrNoRows {
		return nil, nil
	}

	if err != nil {
		return nil, err
	}

	return account, nil
}
