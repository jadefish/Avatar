func (c *Client) dumpBytes(msg string, p []byte, n int) {
	// TODO: remove/toggle debug logging
	log.Printf(
		"(%s) %s: %d bytes:\n%s\n",
		c.conn.RemoteAddr(),
		msg,
		n,
		hex.Dump(p[0:n]),
	)
}
