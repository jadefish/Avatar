package tcp

import (
	"bufio"
	"encoding/hex"
	"io"
	"log"
	"net"

	"github.com/jadefish/avatar/pkg/crypto"
)

type Client struct {
	io.ReadWriteCloser
	crypto.Cryptographer

	conn net.Conn
	rw   *bufio.ReadWriter
}

// NewClient creates a new Client that will use the provided conn for communication.
func NewClient(conn net.Conn) Client {
	r := bufio.NewReaderSize(conn, MaxPacketSize)
	w := bufio.NewWriterSize(conn, MaxPacketSize)

	return Client{
		conn:          conn,
		rw:            bufio.NewReadWriter(r, w),
		Cryptographer: crypto.NilCryptographer,
	}
}

func (c *Client) identifier() string {
	return c.conn.RemoteAddr().String()
}

// Read at most len(p) bytes from the client.
func (c *Client) Read(p []byte) (int, error) {
	return c.rw.Read(p)
}

// Write the contents of p to the client.
func (c *Client) Write(p []byte) (int, error) {
	n, err := c.rw.Write(p)

	if err == nil {
		err = c.rw.Flush()
	}

	return n, err
}

// Close the client's connection.
//
// Any buffered data is written to the client before closing.
func (c *Client) Close() error {
	_ = c.rw.Flush()

	return c.conn.Close()
}

